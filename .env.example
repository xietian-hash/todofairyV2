# 后端服务监听端口
PORT=3000

# MySQL 连接字符串，格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://root:root@127.0.0.1:3306/tasksprite

# JWT 签名密钥，用于生成和验证用户 token，生产环境请使用随机长字符串
JWT_SECRET=replace_me

# JWT 有效期，支持 ms 库格式，如 7d / 24h / 3600s
JWT_EXPIRES_IN=7d

# 微信小程序 AppID，在微信公众平台「开发 → 开发管理」中查看
WECHAT_APPID=replace_me

# 微信小程序 AppSecret，同上位置，用于 code 换取 openid
WECHAT_SECRET=replace_me

# 内部接口鉴权密钥，调用 /api/v1/internal/* 接口时需在请求头 x-internal-key 中传入
# 用于日切、日报、周报等定时任务触发，生产环境请使用随机长字符串
INTERNAL_API_KEY=replace_me

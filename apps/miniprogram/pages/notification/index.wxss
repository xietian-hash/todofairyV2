.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 30rpx calc(30rpx + env(safe-area-inset-bottom));
  background: #f5f7fa;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #f5f7fa;
}

.custom-nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #64748b;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  text-align: center;
}

.settings-card {
  margin-top: 20rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.setting-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-divider {
  padding-top: 18rpx;
  border-top: 1rpx solid #e2e8f0;
}

.setting-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.setting-label {
  font-size: 28rpx;
  color: #1e293b;
}

.setting-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.form-item {
  margin-top: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.input {
  height: 80rpx;
  border-radius: 16rpx;
  padding: 0 20rpx;
  background: #ffffff;
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.08),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
  font-size: 28rpx;
  color: #1e293b;
}

.hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #0f172a;
  line-height: 1.7;
}

.last-test {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #0f766e;
}

.last-test.failed {
  color: #b91c1c;
}

.error-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b91c1c;
}

.actions {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
}

.actions-split {
  margin-top: 16rpx;
}

.ghost-btn,
.secondary-btn,
.primary-btn {
  flex: 1;
  height: 82rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ghost-btn {
  color: #0369a1;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.secondary-btn {
  color: #0f172a;
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #21bfff, #6c5ce7);
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.error-bar {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #ef4444;
}
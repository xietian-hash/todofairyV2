.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

button {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

page {
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  color: #1e293b;
}

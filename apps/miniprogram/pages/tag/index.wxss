.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 30rpx 210rpx;
  background: #f5f7fa;
  color: #1e293b;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #f5f7fa;
}

.custom-nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #64748b;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.nav-back:active {
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.08),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  text-align: center;
}

.loading-state {
  margin-top: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  padding: 26rpx 24rpx;
  font-size: 26rpx;
  text-align: center;
  color: #64748b;
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.05),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.tag-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tag-swipe-item {
  position: relative;
}

.tag-delete-area {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 156rpx;
  display: flex;
  justify-content: flex-end;
  z-index: 1;
}

.tag-delete-btn {
  width: 156rpx;
  height: 100%;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.tag-swipe-content {
  position: relative;
  z-index: 2;
  transition: transform 0.2s ease;
}

.tag-swipe-content.moving {
  transition: none;
}

.tag-card {
  min-height: 130rpx;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.tag-card-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tag-color-dot {
  flex: 0 0 auto;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid;
}

.tag-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-edit-btn {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 56rpx;
  border-radius: 28rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0369a1;
  background: #e0f5ff;
  font-size: 24rpx;
}

.fab-btn {
  position: fixed;
  right: 30rpx;
  bottom: calc(26rpx + env(safe-area-inset-bottom));
  width: 92rpx;
  height: 88rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #21bfff, #6c5ce7);
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
  z-index: 300;
}

.fab-btn:active {
  background: linear-gradient(135deg, #0ea5e9, #5b4bd5);
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.08),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.empty-state {
  margin-top: 30rpx;
  padding: 60rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  background: #ffffff;
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.05),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1e293b;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: flex-end;
}

.modal-panel {
  width: 100%;
  min-height: 360rpx;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  transition: margin-bottom 0.2s ease;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx 12rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.close-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: #64748b;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.close-btn:active {
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.08),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.modal-body {
  padding: 0 30rpx;
}

.form-item {
  margin-top: 12rpx;
}

.input {
  margin-top: 8rpx;
  border: none;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  color: #1e293b;
  min-height: 80rpx;
  background: #ffffff;
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.08),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.input:focus {
  box-shadow: inset 4rpx 4rpx 10rpx rgba(0, 0, 0, 0.1),
    inset -4rpx -4rpx 10rpx rgba(255, 255, 255, 1);
}

.modal-actions {
  display: flex;
  gap: 12rpx;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.ghost-btn,
.primary-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border-radius: 48rpx;
  font-size: 28rpx;
}

.ghost-btn {
  background: #ffffff;
  color: #21bfff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.ghost-btn:active {
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.08),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.primary-btn {
  background: linear-gradient(135deg, #21bfff, #6c5ce7);
  color: #ffffff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.primary-btn:active {
  background: linear-gradient(135deg, #0ea5e9, #5b4bd5);
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.08),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.error-bar {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  min-height: 72rpx;
  border-radius: 20rpx;
  background: #fee2e2;
  color: #b91c1c;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

/* ===== 颜色选择器 ===== */
.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.color-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.color-option {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  border: 3rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 3rpx 3rpx 7rpx rgba(0, 0, 0, 0.05),
    -3rpx -3rpx 7rpx rgba(255, 255, 255, 1);
  transition: all 0.15s ease;
}

.color-option.active {
  box-shadow: inset 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1),
    inset -2rpx -2rpx 4rpx rgba(255, 255, 255, 1);
  transform: scale(0.95);
}

.color-check {
  font-size: 32rpx;
  font-weight: 600;
}

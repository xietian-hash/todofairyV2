.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 30rpx calc(30rpx + env(safe-area-inset-bottom));
  background: #f5f7fa;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #f5f7fa;
}

.custom-nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #64748b;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 0, 0, 0.07),
    -6rpx -6rpx 14rpx rgba(255, 255, 255, 1);
}

.nav-back:active {
  box-shadow: inset 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.08),
    inset -4rpx -4rpx 8rpx rgba(255, 255, 255, 1);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  text-align: center;
}

.menu-content {
  margin-top: 20rpx;
}

.menu-section {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.menu-item {
  min-height: 130rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.menu-item.active {
  background: #e0f5ff;
  border-color: #7dd3fc;
}

.menu-item-title {
  font-size: 28rpx;
  color: #1e293b;
}

.menu-item-desc {
  flex: 0 0 auto;
  font-size: 22rpx;
  color: #64748b;
}
